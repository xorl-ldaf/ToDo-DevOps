SPRING_PROFILES_ACTIVE=prod
TODO_APP_NAME=todo-web-app
TODO_APP_SERVER_PORT=8080
TODO_DB_HOST=postgres.prod.example.internal
TODO_DB_PORT=5432
TODO_DB_NAME=todo
TODO_DB_USERNAME=todo
TODO_KAFKA_ENABLED=true
TODO_KAFKA_BOOTSTRAP_SERVERS=kafka.prod.example.internal:9092
TODO_KAFKA_TOPIC_REMINDER_SCHEDULED_V1=todo.reminder.scheduled.v1
TODO_KAFKA_CONSUMER_GROUP_ID=todo-web-app-reminder-scheduled-v1
TODO_KAFKA_OUTBOX_BATCH_SIZE=25
TODO_KAFKA_OUTBOX_MAX_ATTEMPTS=5
TODO_KAFKA_OUTBOX_RETRY_BACKOFF=10s
TODO_KAFKA_OUTBOX_PROCESSING_TIMEOUT=30s
TODO_KAFKA_OUTBOX_INITIAL_DELAY=5s
TODO_KAFKA_OUTBOX_FIXED_DELAY=10s
TODO_TELEGRAM_ENABLED=false
TODO_TELEGRAM_BASE_URL=https://api.telegram.org
TODO_REMINDER_DELIVERY_ENABLED=false
TODO_REMINDER_DELIVERY_INITIAL_DELAY_MS=5000
TODO_REMINDER_DELIVERY_FIXED_DELAY_MS=30000
TODO_REMINDER_DELIVERY_MAX_ATTEMPTS=3
TODO_REMINDER_DELIVERY_RETRY_BACKOFF=30s
TODO_REMINDER_DELIVERY_PROCESSING_TIMEOUT=30s
TODO_OBS_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info,prometheus
TODO_OBS_HEALTH_SHOW_COMPONENTS=never
TODO_OBS_HEALTH_SHOW_DETAILS=never

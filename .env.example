# Spring profile selection.
# `.env.example` keeps the local stack in `dev`; switch to `prod` only for a prod-like local run.
SPRING_PROFILES_ACTIVE=dev

# Application defaults for local runs.
TODO_APP_NAME=todo-web-app
TODO_APP_SERVER_PORT=8080
TODO_APP_HOST_PORT=8080

# Database connection for local runs.
TODO_DB_HOST=localhost
TODO_DB_PORT=5432
TODO_DB_HOST_PORT=5432
TODO_DB_NAME=todo
TODO_DB_USERNAME=postgres
# Secret. Keep the real value only in your local .env / CI secret store.
TODO_DB_PASSWORD=postgres
# Optional full JDBC URL override. Useful for managed databases; leave commented for local Compose/dev runs.
# TODO_DB_URL=jdbc:postgresql://localhost:5432/todo

# Optional actuator overrides. Leave commented to use profile defaults from `application-{profile}.yml`.
# TODO_OBS_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info,metrics,prometheus
# TODO_OBS_HEALTH_SHOW_COMPONENTS=always
# TODO_OBS_HEALTH_SHOW_DETAILS=always

# Optional Kafka overrides for the local Compose stack.
# Compose enables Kafka by default for the app container; direct bootRun stays disabled unless you export these.
# TODO_KAFKA_ENABLED=true
# TODO_KAFKA_HOST_PORT=9094
# TODO_KAFKA_BOOTSTRAP_SERVERS=localhost:9094
# TODO_KAFKA_TOPIC_REMINDER_SCHEDULED_V1=todo.reminder.scheduled.v1
# TODO_KAFKA_CONSUMER_GROUP_ID=todo-web-app-reminder-scheduled-v1
# TODO_KAFKA_PRODUCER_RETRIES=3
# TODO_KAFKA_PRODUCER_RETRY_BACKOFF=1s
# TODO_KAFKA_PRODUCER_REQUEST_TIMEOUT=5s
# TODO_KAFKA_PRODUCER_DELIVERY_TIMEOUT=20s
# TODO_KAFKA_CONSUMER_MAX_ATTEMPTS=2
# TODO_KAFKA_CONSUMER_RETRY_BACKOFF=1s

# Optional Telegram reminder delivery.
# Chat routing comes from each user's `telegramChatId`, not from an env var.
# TODO_TELEGRAM_ENABLED=true
# TODO_TELEGRAM_BOT_TOKEN=replace-me
# TODO_TELEGRAM_BASE_URL=https://api.telegram.org
# TODO_TELEGRAM_CONNECT_TIMEOUT=2s
# TODO_TELEGRAM_READ_TIMEOUT=5s
# TODO_TELEGRAM_MAX_ATTEMPTS=3
# TODO_TELEGRAM_RETRY_BACKOFF=1s
# TODO_REMINDER_DELIVERY_ENABLED=true
# TODO_REMINDER_DELIVERY_INITIAL_DELAY_MS=5000
# TODO_REMINDER_DELIVERY_FIXED_DELAY_MS=30000
# TODO_REMINDER_DELIVERY_BATCH_SIZE=25
# TODO_APP_SHUTDOWN_TIMEOUT=20s

# Grafana credentials for the local Compose stack.
TODO_GRAFANA_ADMIN_USER=admin
# Secret. Keep the real value only in your local .env / CI secret store.
TODO_GRAFANA_ADMIN_PASSWORD=admin
